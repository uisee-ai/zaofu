# ZaoFu 项目环境变量模板 — 复制为 .env 并填真值(.env 已 gitignore,勿提交真值)。
#
# 加载语义(两条路径,doc 78 O-7):
#   1. `zf start` / `zf web` / `zf feishu` 启动时 load_project_env() 将本文件
#      注入进程环境(non-overriding)——写在这里即对 runtime 生效;
#   2. config loader 对 zf.yaml / feishu.yaml 里的 ${VAR:-默认} 占位符做文本层
#      展开(不污染进程环境)——身份表 / 路由表的键值来自这里。
#   仅当你绕过 zf CLI 直接起进程时,才需要自行 source 本文件。

# ── 飞书 app 凭证(open_id 是 per-app 的,不同 bot 看到同一人的不同 open_id)──
FEISHU_APP_ID=cli_your_main_app_id            # 主 app(webhook/推送默认凭证)
FEISHU_APP_SECRET=your_main_app_secret
FEISHU_KANBAN=cli_your_kanban_bot_app_id      # Kanban Agent bot(feishu.yaml 路由 ${FEISHU_KANBAN})
FEISHU_KANBAN_SECRET=your_kanban_bot_secret
FEISHU_RUNM=cli_your_runm_bot_app_id          # Run Manager bot;告警卡按钮回调走此 app,
FEISHU_RUNM_SECRET=your_runm_bot_secret       #   bridge watch 须用它起,否则按钮"回调不在线"
FEISHU_CH_SECRET=your_channel_verification    # feishu_identity.verification_token_env(webhook 校验)

# ── Operator 身份(feishu.yaml 身份表占位符;缺失→按钮被身份门拒 unmapped→VIEWER)──
FEISHU_OPENID=ou_your_openid_in_main_app      # 你在【主 app】视角的 open_id
FEISHU_OPENID_RUNM=ou_your_openid_in_runm_app # 你在【RUNM app】视角的 open_id(2026-07-17 实弹
                                              #   证实缺它则 RUNM 卡一切按钮全拒)

# ── 告警投递目标 ──
ZF_OWNER_VISIBLE_CHAT=oc_your_alert_chat_id   # owner 告警群 chat_id(feishu.yaml 路由亦引用)
ZF_OWNER_VISIBLE_RECEIVE_ID_TYPE=chat_id
ZF_WEB_BASE_URL=http://your-host:8001         # 告警卡「🔍 详情」深链目标;不配则该按钮不渲染

# ── Web ──
ZF_WEB_ACTION_TOKEN=your_web_action_token     # Web 写动作 token 门

# ── Codex Workflow Worker 本机兼容 ──
# 默认保持注释。仅在可信本地 smoke/E2E 主机缺少 unshare/bubblewrap 能力时启用；
# 该变量只影响 Workflow Worker，不复用 Kanban Agent 的 Web Headless 沙箱设置。
# ZF_CODEX_WORKER_SANDBOX=danger-full-access

# ── 工作区 ──
ZF_WORKSPACE_HOME=/path/to/workspace          # 多项目 workspace 根

# ── 飞书文档/多维表自动化(报告导出侧;不用该功能可整组留空)──
FEISHU_FOLDER_TOKEN=
FEISHU_AUTOMATION_DOCUMENT_ID=
FEISHU_AUTOMATION_DOCUMENT_URL=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=
FEISHU_BITABLE_URL=
FEISHU_AUTOMATION_BITABLE_APP_TOKEN=
FEISHU_AUTOMATION_BITABLE_TABLE_ID=

# 卫生提示:历史 .env 中存在拼写废键 FIESHU_CH(全仓零消费者)与注释行里的旧
# app 明文 secret——迁移到本模板时请一并清理。
